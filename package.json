{
  "license": "GPL-3.0-or-later",
  "scripts": {
    "test:pipeline": "vitest run --config vitest.config.ts",
    "test:pipeline:qa": "vitest run --config vitest.config.ts visualQa.manual",
    "golden:eval": "vitest run --config vitest.golden.config.ts",
    "golden:baseline": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-golden-eval.ps1 -Baseline",
    "golden:regression": "vitest run --config vitest.config.ts goldenEval.regression",
    "test:pipeline:watch": "vitest --config vitest.config.ts",
    "build:eval-consumer": "wrangler deploy --config wrangler-eval-consumer.jsonc --dry-run --outdir=.wrangler/check-eval-bundle --env=\"\"",
    "dev": "wrangler dev --persist-to .wrangler/local-shared",
    "dev:eval-consumer": "wrangler dev --config wrangler-eval-consumer.jsonc --persist-to .wrangler/local-shared",
    "dev:hedron-consumer": "wrangler dev --config wrangler-hedron-consumer.jsonc --persist-to .wrangler/local-shared",
    "dev:all": "wrangler dev -c wrangler.jsonc -c wrangler-eval-consumer.jsonc -c wrangler-hedron-consumer.jsonc --persist-to .wrangler/local-shared",
    "dev:terminals": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-terminals.ps1",
    "d1:bootstrap:local": "wrangler d1 execute cubewizard-db --local --persist-to .wrangler/local-shared --file=./schema.sql",
    "wrangler:check": "wrangler deploy --dry-run --outdir=.wrangler/check-main --env=\"\" && wrangler deploy --dry-run --config wrangler-eval-consumer.jsonc --outdir=.wrangler/check-eval --env=\"\" && wrangler deploy --dry-run --config wrangler-hedron-consumer.jsonc --outdir=.wrangler/check-hedron --env=\"\" && wrangler deploy --dry-run --config wrangler-redirect.jsonc --outdir=.wrangler/check-redirect --env=\"\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@jsquash/webp": "^1.5.0",
    "jpeg-js": "^0.4.4",
    "libheif-js": "^1.19.8",
    "upng-js": "^2.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@types/node": "^25.7.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.56.0"
  }
}
