# Environment variables template  
# Copy this file to .env and fill in your actual values

# OpenAI API Key - Get from https://platform.openai.com/api-keys  
OPENAI_API_KEY=your_openai_api_key_here

# Cloudflare account & API token (used by d1_writer.py for D1 REST API)
# Account ID: Cloudflare Dashboard > any domain or Workers & Pages > right sidebar
# API Token: https://dash.cloudflare.com/profile/api-tokens > Create Token
#   Required permission: Account / D1 / Edit
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_D1_DATABASE_ID=be868abb-addf-433a-a0c3-b5ffb5b22543

# Cloudflare R2 storage credentials (S3-compatible API)
# Generate at: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=decklist-uploads

# Oriented deck images (separate blob bucket; same API token can access both)
R2_ORIENTED_BUCKET_NAME=cubewizard-deck-images