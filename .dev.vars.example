# =============================================================================
# COPY THIS FILE TO `.dev.vars` AND FILL EVERY KEY YOU NEED (values may stay
# empty until you exercise that code path). Wrangler loads `.dev.vars` for any
# `wrangler dev` run in this repo (site worker, eval consumer, hedron consumer).
# =============================================================================

# Optional — when `CWW_ENV` is `local` (default in top-level `wrangler.jsonc`), Turnstile is skipped on upload/add-cube.
# Set for testing Turnstile locally or if you override `CWW_ENV` away from `local`.
TURNSTILE_SECRET=

# --- Eval consumer (`wrangler-eval-consumer.jsonc`) ---
# FILL — required locally (Wrangler loads this as the OPENAI_API_KEY secret).
# Hosted stg/prod: set once with `wrangler secret put OPENAI_API_KEY --config wrangler-eval-consumer.jsonc --env stg` (and `--env prod`).
OPENAI_API_KEY=

# Optional — OpenAI eval consumer log level: off | low | medium | high
CW_EVAL_LOG_LEVEL=

# Optional — max decode/orient pixels per side (default 2048 on Workers)
# CW_EVAL_MAX_IMAGE_SIDE=2048
# CW_EVAL_ORIENT_MAX_SIDE=1280

# --- R2 presigned URLs for OpenAI vision (eval consumer, hosted stg/prod only) ---
# Not needed locally: CWW_ENV=local sends JPEG inline (base64) to OpenAI.
# For stg/prod (or local URL testing): create an R2 API token with Object Read & Write on cubewizard-deck-images.
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Optional — public CDN for cubewizard-deck-images (skips presigning when set on eval consumer)
# DECK_IMAGE_PUBLIC_BASE_URL=
